u0645\u0637\u0627\u0644\u0639\u0647 \u06a9\u0646\u06cc\u062f. \u0631\u0648\u06cc \u0647\u0631 \u062a\u06af \u06a9\u0644\u06cc\u06a9 \u06a9\u0646\u06cc\u062f \u062a\u0627 \u0645\u0637\u0627\u0644\u0628 \u0645\u0631\u062a\u0628\u0637 \u0628\u0627 \u0622\u0646 \u0646\u0645\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0634\u0648\u062f.</p>"},{"location":"tags/#tag:\u062a\u0631\u0627\u0646\u0647","title":"\u062a\u0631\u0627\u0646\u0647","text":"<ul> <li>            \u0628\u06cc\u200c\u0631\u062d\u0645          </li> </ul>"},{"location":"tags/#tag:\u062a\u0646\u0647\u0627\u06cc\u06cc","title":"\u062a\u0646\u0647\u0627\u06cc\u06cc","text":"<ul> <li>            \u0628\u06cc\u200c\u0631\u062d\u0645          </li> </ul>"},{"location":"tags/#tag:\u062f\u0644\u0646\u0648\u0634\u062a\u0647","title":"\u062f\u0644\u0646\u0648\u0634\u062a\u0647","text":"<ul> <li>            \u0628\u06cc\u200c\u0631\u062d\u0645          </li> </ul>"},{"location":"tags/#tag:\u0639\u0627\u0634\u0642\u0627\u0646\u0647","title":"\u0639\u0627\u0634\u0642\u0627\u0646\u0647","text":"<ul> <li>            \u0628\u06cc\u200c\u0631\u062d\u0645          </li> </ul>"},{"location":"tags/#tag:\u0639\u0634\u0642-\u06cc\u06a9\u0637\u0631\u0641\u0647","title":"\u0639\u0634\u0642 \u06cc\u06a9\u200c\u0637\u0631\u0641\u0647","text":"<ul> <li>            \u0628\u06cc\u200c\u0631\u062d\u0645          </li> </ul>"},{"location":"tags/#tag:\u063a\u0631\u0648\u0631","title":"\u063a\u0631\u0648\u0631","text":"<ul> <li>            \u0628\u06cc\u200c\u0631\u062d\u0645          </li> </ul>"},{"location":"posts/%D8%B4%D8%B9%D8%B1/%D9%86%D9%88%D8%B3%D8%AA%D8%A7%D9%84%DA%98%DB%8C/%D8%A8%DB%8C%E2%80%8C%D8%B1%D8%AD%D9%85/","title":"\u0628\u06cc\u200c\u0631\u062d\u0645","text":"","tags":["\u062a\u0631\u0627\u0646\u0647","\u0639\u0627\u0634\u0642\u0627\u0646\u0647","\u0639\u0634\u0642 \u06cc\u06a9\u200c\u0637\u0631\u0641\u0647","\u062a\u0646\u0647\u0627\u06cc\u06cc","\u063a\u0631\u0648\u0631","\u062f\u0644\u0646\u0648\u0634\u062a\u0647"]},{"location":"posts/%D8%B4%D8%B9%D8%B1/%D9%86%D9%88%D8%B3%D8%AA%D8%A7%D9%84%DA%98%DB%8C/%D8%A8%DB%8C%E2%80%8C%D8%B1%D8%AD%D9%85/#_1","title":"\u0628\u06cc\u200c\u0631\u062d\u0645","text":"<p>\u0686\u0642\u062f\u0631 \u062e\u0648\u0628\u0647 \u062a\u0648 \u0628\u06cc\u200c\u0631\u062d\u0645\u06cc\u061b \u0627\u06af\u0631\u0686\u0647 \u0627\u0641\u062a\u062e\u0627\u0631\u06cc \u0646\u06cc\u0633\u062a\u060c \u0648\u0644\u06cc \u0645\u06cc\u200c\u0634\u0647 \u0627\u0632\u0634 \u0641\u0647\u0645\u06cc\u062f: \u06a9\u0647 \u0627\u0632 \u062a\u0648 \u0627\u0646\u062a\u0638\u0627\u0631\u06cc \u0646\u06cc\u0633\u062a...</p> <p>\u0647\u0645\u06cc\u0646 \u062e\u0648\u0628\u0647 \u06a9\u0647 \u0641\u0647\u0645\u06cc\u062f\u0646\u061b \u0628\u0647 \u06cc\u06a9 \u062f\u0646\u06cc\u0627 \u0645\u06cc\u200c\u0627\u0631\u0632\u0647\u060c \u0632\u0645\u06cc\u0646 \u0647\u0645 \u0628\u0627\u0634\u0647 \u0627\u06cc\u0646 \u062f\u0633\u062a\u0627\u061b \u062a\u0648\u06cc\u0650 \u062f\u0633\u062a \u062a\u0648 \u0645\u06cc\u200c\u0644\u0631\u0632\u0647...</p> <p>\u0647\u0645\u06cc\u0646 \u062e\u0648\u0628\u0647 \u06a9\u0647 \u0645\u06cc\u200c\u062f\u0648\u0646\u0645\u061b \u0647\u0645\u06cc\u0646 \u0627\u0648\u0644 \u062f\u0644\u062a \u06af\u06cc\u0631\u0647\u060c \u0628\u0628\u06cc\u0646 \u0627\u06cc\u0646\u0648 \u062f\u0644\u0650 \u062a\u0646\u0647\u0627\u061b \u0628\u0628\u06cc\u0646 \u0639\u0634\u0642 \u062a\u0648 \u0645\u06cc\u200c\u0645\u06cc\u0631\u0647...</p> <p>\u0686\u0647 \u0628\u06cc\u200c\u0631\u062d\u0645\u0627\u0646\u0647 \u062a\u0644\u062e\u06cc \u062a\u0648\u061b \u0686\u062c\u0648\u0631\u06cc \u062c\u0627\u06cc \u0634\u06cc\u0631\u06cc\u0646\u06cc\u061f \u06a9\u0647 \u062d\u062a\u06cc \u0627\u06cc\u0646 \u0627\u0645\u06cc\u062f\u0645 \u0646\u06cc\u0633\u062a: \u06a9\u0647 \u0627\u06cc\u0646 \u0641\u0631\u0647\u0627\u062f\u0648 \u0645\u06cc\u200c\u0628\u06cc\u0646\u06cc...</p> <p>\u0628\u0630\u0627\u0631 \u067e\u0627\u06cc \u063a\u0631\u0648\u0631\u0645 \u06a9\u0647\u061b \u0646\u0645\u06cc\u200c\u06af\u0645 \u0639\u0627\u0634\u0642\u062a \u0647\u0633\u062a\u0645\u060c \u0648\u0644\u06cc \u062a\u0648\u06cc\u0650 \u062f\u0644\u0645 \u0627\u06cc\u0646\u0647: \u06a9\u0647 \u0645\u06cc\u200c\u06af\u0645 \u0644\u0627\u06cc\u0642\u062a \u0647\u0633\u062a\u0645\u061f</p> <p>\u06cc\u0647 \u0631\u0648\u0632 \u062a\u0646\u0647\u0627\u062a\u0631\u06cc\u0646 \u062a\u0646\u0647\u0627\u061b \u06cc\u0647 \u0631\u0648\u0632 \u062a\u0646\u0647\u0627\u062a\u0631\u06cc\u0646 \u0639\u0627\u0634\u0642\u060c \u0686\u062c\u0648\u0631\u06cc \u0631\u062f \u0628\u0634\u0645 \u0627\u0632 \u062a\u0648\u061f \u0628\u0627 \u0627\u06cc\u0646 \u067e\u0627\u0631\u0648\u06cc\u0650 \u0628\u06cc\u200c\u0642\u0627\u06cc\u0642...</p> <p>(\u06cc\u0627\u062f \u0628\u0627\u062f \u0631\u0648\u0632\u06af\u0627\u0631\u0627\u0646: \u06f1\u06f3\u06f9\u06f4)</p>","tags":["\u062a\u0631\u0627\u0646\u0647","\u0639\u0627\u0634\u0642\u0627\u0646\u0647","\u0639\u0634\u0642 \u06cc\u06a9\u200c\u0637\u0631\u0641\u0647","\u062a\u0646\u0647\u0627\u06cc\u06cc","\u063a\u0631\u0648\u0631","\u062f\u0644\u0646\u0648\u0634\u062a\u0647"]}]}